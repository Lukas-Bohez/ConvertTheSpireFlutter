# 
# Convert the Spire Reborn  .gitignore
# 

# Miscellaneous
*.class
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (keep launch.json / tasks.json, ignore settings)
.vscode/settings.json

# 
# Flutter / Dart / Pub
# 
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Generated code
*.g.dart

# Platform generated plugin registrants
/windows/flutter/generated_plugin_registrant.cc
/linux/flutter/generated_plugin_registrant.cc

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# 
# Android
# 
/android/.gradle/
/android/local.properties
/android/key.properties
/android/app/debug
/android/app/profile
/android/app/release

# 
# iOS
# 
ios/Pods/
ios/.symlinks/

# 
# Build artifacts & binaries
# 
*.apk
*.apk.zip
*.exe
media_kit_test_*.apk.zip

# 
# Logs & analysis output
# 
*.log
analyze_output.txt
buildlog.txt
buildlog_*.txt
build_log*.txt
debug_run_log.txt

# 
# Releases (built artifacts, not source)
# 
/releases/

# Temporary source/zips created during release process
local_src.zip
v5_source.zip
temp_src/
*.zip
